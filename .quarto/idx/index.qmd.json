{"title":"TBCA Management Effectiveness and Governance Tool","markdown":{"yaml":{"title":"TBCA Management Effectiveness and Governance Tool","subtitle":"Static Quarto + GitHub Pages prototype"},"containsRefs":false,"markdown":"\n\n<style>\n.tbca-shell {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 1rem 1.25rem 3rem 1.25rem;\n}\n.tbca-grid {\n  display: grid;\n  grid-template-columns: 1.2fr 0.8fr;\n  gap: 1.25rem;\n}\n.tbca-card {\n  background: #fff;\n  border: 1px solid #d9e1e7;\n  border-radius: 16px;\n  padding: 1rem 1.1rem;\n  box-shadow: 0 1px 3px rgba(0,0,0,.05);\n  margin-bottom: 1rem;\n}\n.tbca-card h3, .tbca-card h4 { margin-top: 0; }\n.tbca-section {\n  border-top: 1px solid #edf1f4;\n  margin-top: 1rem;\n  padding-top: 1rem;\n}\n.tbca-question { margin-bottom: 1rem; }\n.tbca-question label.main { font-weight: 600; display:block; margin-bottom:.45rem; }\n.tbca-options label { display:block; font-weight: 400; margin-bottom: .35rem; }\n.tbca-input, .tbca-textarea {\n  width: 100%;\n  border: 1px solid #c7d2da;\n  border-radius: 10px;\n  padding: .65rem .8rem;\n}\n.tbca-textarea { min-height: 110px; }\n.tbca-toolbar {\n  display:flex; flex-wrap:wrap; gap:.6rem; margin:.75rem 0 1rem 0;\n}\n.tbca-btn {\n  border:none; border-radius: 999px; padding:.65rem .95rem; cursor:pointer;\n  background:#0d6efd; color:#fff; font-weight:600;\n}\n.tbca-btn.secondary { background:#6c757d; }\n.tbca-btn.light { background:#eef3f7; color:#213547; }\n.tbca-badge {\n  display:inline-block; padding:.25rem .55rem; border-radius:999px; background:#eef3f7; font-size:.9rem;\n}\n.tbca-kpi { font-size: 2rem; font-weight: 700; margin: .25rem 0; }\n.tbca-small { color:#5c6b77; font-size:.95rem; }\n.tbca-report {\n  white-space: pre-wrap;\n  background:#f8fafb;\n  border-radius: 12px;\n  padding: .9rem;\n  border: 1px solid #e4ebf0;\n}\n@media (max-width: 900px) {\n  .tbca-grid { grid-template-columns: 1fr; }\n}\n</style>\n\n<div class=\"tbca-shell\">\n\n<div class=\"tbca-card\">\n  <h3>Prototype purpose</h3>\n  <p>This is a <strong>GitHub Pages-compatible static prototype</strong>. It demonstrates how the Excel-based tool can become a browser-based workflow with structured questions, transparent scoring, local save/export, and a workshop-ready summary report.</p>\n  <div class=\"tbca-toolbar\">\n    <button class=\"tbca-btn\" onclick=\"saveLocal()\">Save in browser</button>\n    <button class=\"tbca-btn secondary\" onclick=\"downloadJSON()\">Export JSON</button>\n    <button class=\"tbca-btn light\" onclick=\"window.print()\">Print / Save PDF</button>\n    <button class=\"tbca-btn light\" onclick=\"clearFormData()\">Clear</button>\n  </div>\n  <div class=\"tbca-small\">For a first release on GitHub Pages, responses are stored in the participant's browser and can be exported for workshop collation.</div>\n</div>\n\n<div class=\"tbca-grid\">\n  <div>\n    <div id=\"form-host\"></div>\n  </div>\n  <div>\n    <div class=\"tbca-card\">\n      <h4>Assessment summary</h4>\n      <div class=\"tbca-badge\">Live scoring</div>\n      <div id=\"overall-score\" class=\"tbca-kpi\">–</div>\n      <div id=\"overall-label\" class=\"tbca-small\">Complete the scored questions to see a summary.</div>\n    </div>\n\n    <div class=\"tbca-card\">\n      <h4>Section scores</h4>\n      <div id=\"section-scores\"></div>\n    </div>\n\n    <div class=\"tbca-card\">\n      <h4>Automated report preview</h4>\n      <div id=\"report-preview\" class=\"tbca-report\">No report text yet.</div>\n    </div>\n  </div>\n</div>\n\n</div>\n\n<script>\nlet QUESTIONS = [];\nconst STORAGE_KEY = \"tbca-prototype-v1\";\n\nasync function initTool() {\n  const res = await fetch('questions.json');\n  QUESTIONS = await res.json();\n  renderForm();\n  loadLocal();\n  updateSummary();\n}\n\nfunction groupedQuestions() {\n  const out = {};\n  QUESTIONS.forEach(q => {\n    if (!out[q.section]) out[q.section] = [];\n    out[q.section].push(q);\n  });\n  return out;\n}\n\nfunction renderForm() {\n  const host = document.getElementById('form-host');\n  const groups = groupedQuestions();\n  host.innerHTML = Object.entries(groups).map(([section, questions]) => `\n    <div class=\"tbca-card\">\n      <h3>${section}</h3>\n      ${questions.map(renderQuestion).join('')}\n    </div>\n  `).join('');\n}\n\nfunction renderQuestion(q) {\n  if (q.type === 'text') {\n    return `\n      <div class=\"tbca-question\">\n        <label class=\"main\" for=\"${q.id}\">${q.label}</label>\n        <input class=\"tbca-input\" id=\"${q.id}\" type=\"text\" oninput=\"updateSummary()\" />\n      </div>`;\n  }\n  if (q.type === 'textarea') {\n    return `\n      <div class=\"tbca-question\">\n        <label class=\"main\" for=\"${q.id}\">${q.label}</label>\n        <textarea class=\"tbca-textarea\" id=\"${q.id}\" oninput=\"updateSummary()\"></textarea>\n      </div>`;\n  }\n  if (q.type === 'score') {\n    return `\n      <div class=\"tbca-question\">\n        <label class=\"main\">${q.label}</label>\n        <div class=\"tbca-options\">\n          ${q.options.map(opt => `\n            <label>\n              <input type=\"radio\" name=\"${q.id}\" value=\"${opt.value}\" onchange=\"updateSummary()\" />\n              ${opt.label} <span class=\"tbca-small\">(${opt.value})</span>\n            </label>\n          `).join('')}\n        </div>\n      </div>`;\n  }\n  return '';\n}\n\nfunction getValue(q) {\n  if (q.type === 'text' || q.type === 'textarea') {\n    return document.getElementById(q.id)?.value || '';\n  }\n  if (q.type === 'score') {\n    const checked = document.querySelector(`input[name=\"${q.id}\"]:checked`);\n    return checked ? Number(checked.value) : null;\n  }\n  return null;\n}\n\nfunction setValue(q, value) {\n  if (value === undefined || value === null) return;\n  if (q.type === 'text' || q.type === 'textarea') {\n    const el = document.getElementById(q.id);\n    if (el) el.value = value;\n  }\n  if (q.type === 'score') {\n    const el = document.querySelector(`input[name=\"${q.id}\"][value=\"${value}\"]`);\n    if (el) el.checked = true;\n  }\n}\n\nfunction collectData() {\n  const data = {};\n  QUESTIONS.forEach(q => data[q.id] = getValue(q));\n  return data;\n}\n\nfunction saveLocal() {\n  localStorage.setItem(STORAGE_KEY, JSON.stringify(collectData()));\n  alert('Responses saved in this browser.');\n}\n\nfunction loadLocal() {\n  const raw = localStorage.getItem(STORAGE_KEY);\n  if (!raw) return;\n  try {\n    const data = JSON.parse(raw);\n    QUESTIONS.forEach(q => setValue(q, data[q.id]));\n  } catch (e) {\n    console.error(e);\n  }\n}\n\nfunction clearFormData() {\n  if (!confirm('Clear all answers in this browser?')) return;\n  localStorage.removeItem(STORAGE_KEY);\n  QUESTIONS.forEach(q => {\n    if (q.type === 'text' || q.type === 'textarea') {\n      const el = document.getElementById(q.id);\n      if (el) el.value = '';\n    }\n    if (q.type === 'score') {\n      document.querySelectorAll(`input[name=\"${q.id}\"]`).forEach(el => el.checked = false);\n    }\n  });\n  updateSummary();\n}\n\nfunction downloadJSON() {\n  const payload = {\n    exported_at: new Date().toISOString(),\n    tool: 'TBCA Governance Tool Prototype',\n    responses: collectData()\n  };\n  const blob = new Blob([JSON.stringify(payload, null, 2)], {type: 'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = 'tbca_responses.json';\n  a.click();\n  URL.revokeObjectURL(url);\n}\n\nfunction updateSummary() {\n  const scores = QUESTIONS.filter(q => q.type === 'score').map(q => ({section: q.section, value: getValue(q)})).filter(x => x.value !== null);\n  const total = scores.length ? scores.reduce((a,b) => a+b.value, 0) / scores.length : null;\n  document.getElementById('overall-score').textContent = total ? total.toFixed(1) + ' / 5' : '–';\n  document.getElementById('overall-label').textContent = total ? interpretScore(total) : 'Complete the scored questions to see a summary.';\n\n  const bySection = {};\n  scores.forEach(x => {\n    if (!bySection[x.section]) bySection[x.section] = [];\n    bySection[x.section].push(x.value);\n  });\n  document.getElementById('section-scores').innerHTML = Object.entries(bySection).map(([section, vals]) => {\n    const avg = vals.reduce((a,b)=>a+b,0)/vals.length;\n    return `<div class=\"tbca-section\"><strong>${section}</strong><div>${avg.toFixed(1)} / 5</div><div class=\"tbca-small\">${interpretScore(avg)}</div></div>`;\n  }).join('') || '<div class=\"tbca-small\">No scored answers yet.</div>';\n\n  buildReport(total, bySection);\n}\n\nfunction interpretScore(x) {\n  if (x >= 4) return 'Strong readiness / favourable conditions';\n  if (x >= 3) return 'Moderate feasibility with areas needing support';\n  return 'Substantial barriers or risks to address';\n}\n\nfunction buildReport(total, bySection) {\n  const data = collectData();\n  const lines = [];\n  lines.push('TBCA MANAGEMENT EFFECTIVENESS AND GOVERNANCE TOOL — WORKSHOP SUMMARY');\n  lines.push('');\n  lines.push(`Initiative: ${data.A1_name || '[not filled]'}`);\n  lines.push(`Countries: ${data.A1_countries || '[not filled]'}`);\n  lines.push('');\n  lines.push(`Overall indicative score: ${total ? total.toFixed(1) + ' / 5' : '[not enough information]'}`);\n  if (total) lines.push(`Interpretation: ${interpretScore(total)}`);\n  lines.push('');\n  lines.push('Section overview:');\n  if (Object.keys(bySection).length === 0) {\n    lines.push('- No scored responses yet.');\n  } else {\n    Object.entries(bySection).forEach(([section, vals]) => {\n      const avg = vals.reduce((a,b)=>a+b,0)/vals.length;\n      lines.push(`- ${section}: ${avg.toFixed(1)} / 5 (${interpretScore(avg)})`);\n    });\n  }\n  lines.push('');\n  lines.push('Discussion points:');\n  if (data.general_comment) {\n    lines.push(data.general_comment);\n  } else {\n    lines.push('[no notes added]');\n  }\n  document.getElementById('report-preview').textContent = lines.join('\\n');\n}\n\ninitTool();\n</script>\n","srcMarkdownNoYaml":"\n\n<style>\n.tbca-shell {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 1rem 1.25rem 3rem 1.25rem;\n}\n.tbca-grid {\n  display: grid;\n  grid-template-columns: 1.2fr 0.8fr;\n  gap: 1.25rem;\n}\n.tbca-card {\n  background: #fff;\n  border: 1px solid #d9e1e7;\n  border-radius: 16px;\n  padding: 1rem 1.1rem;\n  box-shadow: 0 1px 3px rgba(0,0,0,.05);\n  margin-bottom: 1rem;\n}\n.tbca-card h3, .tbca-card h4 { margin-top: 0; }\n.tbca-section {\n  border-top: 1px solid #edf1f4;\n  margin-top: 1rem;\n  padding-top: 1rem;\n}\n.tbca-question { margin-bottom: 1rem; }\n.tbca-question label.main { font-weight: 600; display:block; margin-bottom:.45rem; }\n.tbca-options label { display:block; font-weight: 400; margin-bottom: .35rem; }\n.tbca-input, .tbca-textarea {\n  width: 100%;\n  border: 1px solid #c7d2da;\n  border-radius: 10px;\n  padding: .65rem .8rem;\n}\n.tbca-textarea { min-height: 110px; }\n.tbca-toolbar {\n  display:flex; flex-wrap:wrap; gap:.6rem; margin:.75rem 0 1rem 0;\n}\n.tbca-btn {\n  border:none; border-radius: 999px; padding:.65rem .95rem; cursor:pointer;\n  background:#0d6efd; color:#fff; font-weight:600;\n}\n.tbca-btn.secondary { background:#6c757d; }\n.tbca-btn.light { background:#eef3f7; color:#213547; }\n.tbca-badge {\n  display:inline-block; padding:.25rem .55rem; border-radius:999px; background:#eef3f7; font-size:.9rem;\n}\n.tbca-kpi { font-size: 2rem; font-weight: 700; margin: .25rem 0; }\n.tbca-small { color:#5c6b77; font-size:.95rem; }\n.tbca-report {\n  white-space: pre-wrap;\n  background:#f8fafb;\n  border-radius: 12px;\n  padding: .9rem;\n  border: 1px solid #e4ebf0;\n}\n@media (max-width: 900px) {\n  .tbca-grid { grid-template-columns: 1fr; }\n}\n</style>\n\n<div class=\"tbca-shell\">\n\n<div class=\"tbca-card\">\n  <h3>Prototype purpose</h3>\n  <p>This is a <strong>GitHub Pages-compatible static prototype</strong>. It demonstrates how the Excel-based tool can become a browser-based workflow with structured questions, transparent scoring, local save/export, and a workshop-ready summary report.</p>\n  <div class=\"tbca-toolbar\">\n    <button class=\"tbca-btn\" onclick=\"saveLocal()\">Save in browser</button>\n    <button class=\"tbca-btn secondary\" onclick=\"downloadJSON()\">Export JSON</button>\n    <button class=\"tbca-btn light\" onclick=\"window.print()\">Print / Save PDF</button>\n    <button class=\"tbca-btn light\" onclick=\"clearFormData()\">Clear</button>\n  </div>\n  <div class=\"tbca-small\">For a first release on GitHub Pages, responses are stored in the participant's browser and can be exported for workshop collation.</div>\n</div>\n\n<div class=\"tbca-grid\">\n  <div>\n    <div id=\"form-host\"></div>\n  </div>\n  <div>\n    <div class=\"tbca-card\">\n      <h4>Assessment summary</h4>\n      <div class=\"tbca-badge\">Live scoring</div>\n      <div id=\"overall-score\" class=\"tbca-kpi\">–</div>\n      <div id=\"overall-label\" class=\"tbca-small\">Complete the scored questions to see a summary.</div>\n    </div>\n\n    <div class=\"tbca-card\">\n      <h4>Section scores</h4>\n      <div id=\"section-scores\"></div>\n    </div>\n\n    <div class=\"tbca-card\">\n      <h4>Automated report preview</h4>\n      <div id=\"report-preview\" class=\"tbca-report\">No report text yet.</div>\n    </div>\n  </div>\n</div>\n\n</div>\n\n<script>\nlet QUESTIONS = [];\nconst STORAGE_KEY = \"tbca-prototype-v1\";\n\nasync function initTool() {\n  const res = await fetch('questions.json');\n  QUESTIONS = await res.json();\n  renderForm();\n  loadLocal();\n  updateSummary();\n}\n\nfunction groupedQuestions() {\n  const out = {};\n  QUESTIONS.forEach(q => {\n    if (!out[q.section]) out[q.section] = [];\n    out[q.section].push(q);\n  });\n  return out;\n}\n\nfunction renderForm() {\n  const host = document.getElementById('form-host');\n  const groups = groupedQuestions();\n  host.innerHTML = Object.entries(groups).map(([section, questions]) => `\n    <div class=\"tbca-card\">\n      <h3>${section}</h3>\n      ${questions.map(renderQuestion).join('')}\n    </div>\n  `).join('');\n}\n\nfunction renderQuestion(q) {\n  if (q.type === 'text') {\n    return `\n      <div class=\"tbca-question\">\n        <label class=\"main\" for=\"${q.id}\">${q.label}</label>\n        <input class=\"tbca-input\" id=\"${q.id}\" type=\"text\" oninput=\"updateSummary()\" />\n      </div>`;\n  }\n  if (q.type === 'textarea') {\n    return `\n      <div class=\"tbca-question\">\n        <label class=\"main\" for=\"${q.id}\">${q.label}</label>\n        <textarea class=\"tbca-textarea\" id=\"${q.id}\" oninput=\"updateSummary()\"></textarea>\n      </div>`;\n  }\n  if (q.type === 'score') {\n    return `\n      <div class=\"tbca-question\">\n        <label class=\"main\">${q.label}</label>\n        <div class=\"tbca-options\">\n          ${q.options.map(opt => `\n            <label>\n              <input type=\"radio\" name=\"${q.id}\" value=\"${opt.value}\" onchange=\"updateSummary()\" />\n              ${opt.label} <span class=\"tbca-small\">(${opt.value})</span>\n            </label>\n          `).join('')}\n        </div>\n      </div>`;\n  }\n  return '';\n}\n\nfunction getValue(q) {\n  if (q.type === 'text' || q.type === 'textarea') {\n    return document.getElementById(q.id)?.value || '';\n  }\n  if (q.type === 'score') {\n    const checked = document.querySelector(`input[name=\"${q.id}\"]:checked`);\n    return checked ? Number(checked.value) : null;\n  }\n  return null;\n}\n\nfunction setValue(q, value) {\n  if (value === undefined || value === null) return;\n  if (q.type === 'text' || q.type === 'textarea') {\n    const el = document.getElementById(q.id);\n    if (el) el.value = value;\n  }\n  if (q.type === 'score') {\n    const el = document.querySelector(`input[name=\"${q.id}\"][value=\"${value}\"]`);\n    if (el) el.checked = true;\n  }\n}\n\nfunction collectData() {\n  const data = {};\n  QUESTIONS.forEach(q => data[q.id] = getValue(q));\n  return data;\n}\n\nfunction saveLocal() {\n  localStorage.setItem(STORAGE_KEY, JSON.stringify(collectData()));\n  alert('Responses saved in this browser.');\n}\n\nfunction loadLocal() {\n  const raw = localStorage.getItem(STORAGE_KEY);\n  if (!raw) return;\n  try {\n    const data = JSON.parse(raw);\n    QUESTIONS.forEach(q => setValue(q, data[q.id]));\n  } catch (e) {\n    console.error(e);\n  }\n}\n\nfunction clearFormData() {\n  if (!confirm('Clear all answers in this browser?')) return;\n  localStorage.removeItem(STORAGE_KEY);\n  QUESTIONS.forEach(q => {\n    if (q.type === 'text' || q.type === 'textarea') {\n      const el = document.getElementById(q.id);\n      if (el) el.value = '';\n    }\n    if (q.type === 'score') {\n      document.querySelectorAll(`input[name=\"${q.id}\"]`).forEach(el => el.checked = false);\n    }\n  });\n  updateSummary();\n}\n\nfunction downloadJSON() {\n  const payload = {\n    exported_at: new Date().toISOString(),\n    tool: 'TBCA Governance Tool Prototype',\n    responses: collectData()\n  };\n  const blob = new Blob([JSON.stringify(payload, null, 2)], {type: 'application/json'});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = 'tbca_responses.json';\n  a.click();\n  URL.revokeObjectURL(url);\n}\n\nfunction updateSummary() {\n  const scores = QUESTIONS.filter(q => q.type === 'score').map(q => ({section: q.section, value: getValue(q)})).filter(x => x.value !== null);\n  const total = scores.length ? scores.reduce((a,b) => a+b.value, 0) / scores.length : null;\n  document.getElementById('overall-score').textContent = total ? total.toFixed(1) + ' / 5' : '–';\n  document.getElementById('overall-label').textContent = total ? interpretScore(total) : 'Complete the scored questions to see a summary.';\n\n  const bySection = {};\n  scores.forEach(x => {\n    if (!bySection[x.section]) bySection[x.section] = [];\n    bySection[x.section].push(x.value);\n  });\n  document.getElementById('section-scores').innerHTML = Object.entries(bySection).map(([section, vals]) => {\n    const avg = vals.reduce((a,b)=>a+b,0)/vals.length;\n    return `<div class=\"tbca-section\"><strong>${section}</strong><div>${avg.toFixed(1)} / 5</div><div class=\"tbca-small\">${interpretScore(avg)}</div></div>`;\n  }).join('') || '<div class=\"tbca-small\">No scored answers yet.</div>';\n\n  buildReport(total, bySection);\n}\n\nfunction interpretScore(x) {\n  if (x >= 4) return 'Strong readiness / favourable conditions';\n  if (x >= 3) return 'Moderate feasibility with areas needing support';\n  return 'Substantial barriers or risks to address';\n}\n\nfunction buildReport(total, bySection) {\n  const data = collectData();\n  const lines = [];\n  lines.push('TBCA MANAGEMENT EFFECTIVENESS AND GOVERNANCE TOOL — WORKSHOP SUMMARY');\n  lines.push('');\n  lines.push(`Initiative: ${data.A1_name || '[not filled]'}`);\n  lines.push(`Countries: ${data.A1_countries || '[not filled]'}`);\n  lines.push('');\n  lines.push(`Overall indicative score: ${total ? total.toFixed(1) + ' / 5' : '[not enough information]'}`);\n  if (total) lines.push(`Interpretation: ${interpretScore(total)}`);\n  lines.push('');\n  lines.push('Section overview:');\n  if (Object.keys(bySection).length === 0) {\n    lines.push('- No scored responses yet.');\n  } else {\n    Object.entries(bySection).forEach(([section, vals]) => {\n      const avg = vals.reduce((a,b)=>a+b,0)/vals.length;\n      lines.push(`- ${section}: ${avg.toFixed(1)} / 5 (${interpretScore(avg)})`);\n    });\n  }\n  lines.push('');\n  lines.push('Discussion points:');\n  if (data.general_comment) {\n    lines.push(data.general_comment);\n  } else {\n    lines.push('[no notes added]');\n  }\n  document.getElementById('report-preview').textContent = lines.join('\\n');\n}\n\ninitTool();\n</script>\n"},"formats":{"html":{"identifier":{"display-name":"HTML","target-format":"html","base-format":"html"},"execute":{"f